{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "node backend/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "clean:vite": "node -e \"require('fs').rmSync('node_modules/.vite-temp',{recursive:true,force:true})\"",
    "build": "npm run clean:vite && vite build",
    "build:prod": "npm run clean:vite && tsc -b && vite build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview",
    "install-deps": "npm install",
    "clean": "rm -rf node_modules package-lock.json && npm cache clean --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
