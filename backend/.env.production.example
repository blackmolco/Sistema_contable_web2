# ============================================================
# PRODUCCIÓN — copia este archivo a .env y llena los valores
# ============================================================

# --- Supabase (PostgreSQL) ---
# Obtén ambas URLs en: Supabase → Settings → Database → Connection string
# "Transaction pooler" para DATABASE_URL  (puerto 6543)
# "Session pooler" o "Direct" para DIRECT_URL (puerto 5432)
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# --- Servidor ---
PORT=3001
NODE_ENV=production
HTTPS_ENABLED=true

# --- CORS: URL de tu frontend en Vercel ---
CORS_ORIGINS=https://tu-app.vercel.app

# --- JWT (genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ---
JWT_SECRET=REEMPLAZA_CON_64_BYTES_HEX
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_API_TOKEN=REEMPLAZA_CON_64_BYTES_HEX

# --- SII (opcional, solo si usas sincronización SII) ---
SII_API_URL=https://palmera.sii.cl
SII_API_ENV=cert
SII_CERT_PATH=
SII_KEY_PATH=

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=logs/backend.log

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WRITE_MAX=60

# --- Uploads ---
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=uploads

# --- Parámetros tributarios Chile ---
UIT_ACTUAL=65446
TASA_IVA=0.19
RETENCION_HONORARIOS=0.10
AFP_APORTE_TRABAJADOR=0.10
SIS_TASA=0.0153
SALUD_TASA=0.07
AFC_CONTRATA=0.006
AFC_PLAZO_FIJO=0.024

# --- SMTP (alertas de error, opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@contable.cl

# --- Backup (en Render free el disco es efímero, desactívalo) ---
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_DIR=backups
