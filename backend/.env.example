# ==========================================
# Sistema Contable Chile - Variables de Entorno
# ==========================================
# NUNCA commitees el archivo .env con valores reales.
# Genera secrets seguros con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Base de datos ---
DATABASE_URL="file:./dev.db"
# Para produccion usar PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/contable_chile?schema=public"

# --- Servidor ---
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Autenticacion ---
JWT_SECRET=cambiar_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_API_TOKEN=token_admin_temporal_cambiar_en_produccion

# --- Seguridad ---
HTTPS_ENABLED=false
# En produccion poner true y configurar certificados
# SSL_CERT_PATH=/etc/ssl/certs/contable.crt
# SSL_KEY_PATH=/etc/ssl/private/contable.key

# --- SII API (para integracion real) ---
SII_API_URL=https://palmera.sii.cl
SII_API_ENV=cert
SII_CERT_PATH=
SII_KEY_PATH=
SII_SEMILLA_PATH=
SII_RUT_EMPRESA=
SII_DV_EMPRESA=

# --- Logging ---
LOG_LEVEL=debug
LOG_FILE=logs/backend.log

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_WRITE_MAX=60

# --- Uploads ---
UPLOAD_MAX_SIZE=52428800
UPLOAD_DIR=uploads

# --- Normativa (valores por defecto, se actualizan via API) ---
UIT_ACTUAL=65446
TASA_IVA=0.19
RETENCION_HONORARIOS=0.10
AFP_APORTE_TRABAJADOR=0.10
SIS_TASA=0.0153
SALUD_TASA=0.07
AFC_CONTRATA=0.006
AFC_PLAZO_FIJO=0.024

# --- Email (para notificaciones) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@contable.cl

# --- Backup ---
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_DIR=backups
